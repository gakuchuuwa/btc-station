# Phase 1 不需要任何环境变量

# Phase 2.1 启用（在 Vercel Dashboard 和本地 .env.local 填入）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # 仅服务端使用，绝不放 NEXT_PUBLIC_

# OKX 公共 API 无需 Key，预留变量方便未来配置
OKX_API_BASE=https://www.okx.com

# Phase 4 启用
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# 可选备用新闻源
# CRYPTOPANIC_TOKEN=
